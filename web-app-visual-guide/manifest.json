{
  "manifest_version": 3,
  "name": "Web App Visual Guide",
  "version": "1.0.0",
  "description": "AIがウェブアプリの操作をリアルタイムで視覚的にガイドします",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/dom-analyzer.js", "content/overlay.js", "content/content.js"],
      "css": []
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}



{
  "manifest_version": 3,
  "name": "あなたの拡張機能の名前",
